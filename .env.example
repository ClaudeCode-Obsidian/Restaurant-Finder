# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored — your keys will not be committed.

# Anthropic Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud API key — enable these APIs in Google Cloud Console:
#   - Places API (New)
#   - Maps JavaScript API
GOOGLE_MAPS_API_KEY=AIza...

# Public (exposed to browser) version of the same Google Maps key.
# Restrict it to "HTTP referrers" for your domain in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
